# ─────────────────────────────────────────────────────────────
# Truth-Anchor — environment config. Copy this file to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# ── LLM: Groq (required) ──────────────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here
# Chat model for classification/reply JSON:
GROQ_MODEL=llama-3.3-70b-versatile
# Whisper model for Gujarati speech-to-text (ASR):
GROQ_WHISPER_MODEL=whisper-large-v3

# ── Demo mode ─────────────────────────────────────────────────
# cache = the 3 scripted scenarios (A/B/C) always serve their pre-seeded,
#         deterministic bundle (transcript + JSON + audio). Bulletproof for filming.
# live  = force the real pipeline (Groq Whisper + Groq LLM + TTS) even for A/B/C,
#         with graceful fallback to cache if any API call fails.
# Mic-recorded / non-scripted input ALWAYS runs live regardless of this setting.
DEMO_MODE=cache

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── Sarvam AI TTS (OPTIONAL, preferred voice) ─────────────────
# Natural Indic voices. Get a key at https://dashboard.sarvam.ai
# If set, used as the preferred Gujarati TTS (Google TTS stays as free fallback).
SARVAM_API_KEY=
SARVAM_MODEL=bulbul:v2
SARVAM_SPEAKER=anushka

# ── Bhashini / ULCA (OPTIONAL) ────────────────────────────────
# Leave blank to skip Bhashini entirely (ASR falls back to Groq Whisper,
# TTS falls back to free Google Translate TTS). Fill these once you have a
# key from https://bhashini.gov.in (free for PoC) to use the real Indic pipeline.
BHASHINI_USER_ID=
BHASHINI_ULCA_API_KEY=
# MeitY public pipeline id (default is fine):
BHASHINI_PIPELINE_ID=64392f96daac500b55c543cd

# ── Timeouts ──────────────────────────────────────────────────
# Max ms to wait on any single external API call before falling back.
API_TIMEOUT_MS=8000

# ── Part F: live web grounding for freeform claims (OPTIONAL) ──
# off = use only the curated src/sources.js map. on = also try a quick, timeout-guarded
# web lookup to cite a current source (never fabricates; falls back to curated/generic).
LIVE_GROUNDING=off
