{
  "name": "Truth-Anchor",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "containerEnv": {
    "PUPPETEER_SKIP_DOWNLOAD": "true"
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Truth-Anchor Web UI",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  }
}
